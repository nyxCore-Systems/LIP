  }
  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(139,92,246,0.2), 0 0 10px rgba(139,92,246,0.4); }
    50%       { box-shadow: 0 0 0 5px rgba(139,92,246,0.1), 0 0 20px rgba(139,92,246,0.7); }
  }

  .dot-affected {
    background: var(--amber);
    box-shadow: 0 0 6px rgba(245,158,11,0.4);
  }

  .hz-line-v {
    width: 1px;
    flex: 1;
    min-height: 20px;
    background: linear-gradient(to bottom, rgba(139,92,246,0.4), rgba(245,158,11,0.3));
    margin: 3px 0;
  }
  .hz-line-last {
    background: transparent;
  }

  .hz-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding-bottom: 12px;
  }

  .hz-file {
    font-family: var(--mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-bright);
  }

  .hz-sym {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--muted);
  }

  .hz-badge {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 4px;
    align-self: flex-start;
    margin-top: 4px;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }
  .badge-saved {
    background: rgba(139,92,246,0.15);
    color: #c4b5fd;
    border: 1px solid rgba(139,92,246,0.25);
  }
  .badge-ok {
    background: rgba(245,158,11,0.1);
    color: #fbbf24;
    border: 1px solid rgba(245,158,11,0.2);
  }

  .hz-safe {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    padding: 8px 12px;
    background: rgba(16,185,129,0.05);
    border: 1px solid rgba(16,185,129,0.12);
    border-radius: var(--radius-sm);
    animation: node-appear 0.5s cubic-bezier(0.16,1,0.3,1) 0.85s both;
  }
  .hz-safe-count {
    font-family: var(--mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--green);
  }
  .hz-safe-text {
    font-size: 0.72rem;
    color: var(--muted);
    flex: 1;
  }
  .hz-safe-formula {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: rgba(16,185,129,0.6);
    background: rgba(16,185,129,0.08);
    padding: 1px 7px;
    border-radius: 4px;
  }

  .hz-upgrade {
    margin: 12px 0 0;
    padding: 10px 12px;
    background: rgba(139,92,246,0.05);
    border: 1px solid rgba(139,92,246,0.12);
    border-radius: var(--radius-sm);
    animation: node-appear 0.5s cubic-bezier(0.16,1,0.3,1) 1.1s both;
  }
  .hz-upgrade-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }
  .hz-upgrade-row:last-child { margin-bottom: 0; }
  .hz-upg-label { font-size: 0.7rem; color: var(--muted); }
  .hz-upg-files { font-family: var(--mono); font-size: 0.68rem; color: var(--accent); }
  .hz-upg-bar-wrap {
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    margin-bottom: 6px;
    overflow: hidden;
  }
  .hz-upg-bar {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
    border-radius: 2px;
    animation: bar-fill 1s ease 1.3s both;
    transform-origin: left;
  }
  @keyframes bar-fill {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
  .hz-upg-detail { font-size: 0.68rem; color: var(--muted-2); font-family: var(--mono); }
  .hz-upg-score  { font-family: var(--mono); font-size: 0.68rem; color: var(--accent-2); }

  /* hz-card tier footer */
  .hz-footer {
    display: flex;
    align-items: center;
    border-top: 1px solid var(--border-muted);
    background: rgba(255,255,255,0.02);
  }
  .hz-fstat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 10px 12px;
    flex: 1;
  }
  .hz-fval {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--accent);
  }
  .hz-flabel {
    font-size: 0.62rem;
    color: var(--muted-2);
    white-space: nowrap;
  }
  .hz-fdiv {
    width: 1px;
    height: 28px;
    background: var(--border-muted);
    flex-shrink: 0;
  }

  /* ecosystem compat row */
  .hero-compat {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .compat-label {
    color: var(--muted-2);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .compat-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--muted);
    font-size: 0.78rem;
    padding: 3px 9px;
    border: 1px solid var(--border-muted);
    border-radius: 100px;
    background: rgba(255,255,255,0.03);
    transition: border-color 0.15s, color 0.15s;
  }
  .compat-item:hover {
    border-color: rgba(139,92,246,0.3);
    color: var(--text);
  }
  .compat-item svg {
    opacity: 0.6;
  }
  .compat-sep {
    color: var(--muted-2);
  }

  /* ── TERMINAL ── */
  .terminal {
    background: var(--bg-terminal);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(139, 92, 246, 0.06);
    font-family: var(--mono);
    font-size: 0.82rem;
    display: flex;
    flex-direction: column;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--border-muted);
  }
  .tdot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .tdot-red    { background: #ff5f57; }
  .tdot-yellow { background: #febc2e; }
  .tdot-green  { background: #28c840; }
  .terminal-title {
    margin-left: 6px;
    font-size: 0.72rem;
    color: var(--muted-2);
  }
  .terminal-body {
    padding: 20px 24px 24px;
    line-height: 1.8;
  }
  .tline { display: flex; flex-wrap: wrap; }
  .tgap  { margin-top: 12px; }
  .tprompt { color: var(--accent); margin-right: 10px; user-select: none; }
  .tindent { display: inline-block; width: 20px; }
  .tcmd   { color: #c4cfff; }
  .tout   { color: #9ba8c0; padding-left: 0; }
  .tdim   { color: var(--muted-2); }
  .tkey   { color: #7dd3fc; }
  .tstr   { color: #f87171; }
  .tnum   { color: #86efac; }
  .tcursor {
    display: inline-block;
    color: var(--accent);
    animation: blink 1s step-end infinite;
  }

  /* ── TERMINAL SECTION ── */
  .terminal-section {
    padding: 32px 0 64px;
  }
  .terminal-section .terminal {
    max-width: 900px;
    margin: 0 auto;
  }

  /* ── LAYER SECTION ── */
  .layer-section {
    padding: 100px 0;
    border-top: 1px solid var(--border-muted);
  }
  .layer-cards {
    display: grid;
    grid-template-columns: 1fr 1.1fr 1fr;
    gap: 20px;
    margin-top: 56px;
  }
  .layer-card {
    background: var(--bg-card);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius);
    padding: 28px;
    position: relative;
    overflow: hidden;
  }
  .layer-card-lip {
    border-color: rgba(139, 92, 246, 0.3);
    background: linear-gradient(145deg, rgba(139, 92, 246, 0.06), var(--bg-card));
  }
  .layer-card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.12), transparent 60%);
    pointer-events: none;
  }
  .layer-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }
  .layer-tag {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.08em;
  }
  .lsp-tag  { background: rgba(59, 130, 246, 0.15); color: #7dd3fc; }
  .lip-tag  { background: rgba(139, 92, 246, 0.2);  color: #c4b5fd; }
  .scip-tag { background: rgba(16, 185, 129, 0.15); color: #6ee7b7; }
  .layer-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
  }
  .layer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
  }
  .layer-list li {
    font-size: 0.85rem;
    color: var(--muted);
    padding-left: 16px;
    position: relative;
  }
  .layer-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--muted-2);
  }
  .layer-list li.good {
    color: var(--text);
  }
  .layer-list li.good::before {
    content: '✓';
    color: var(--green);
  }
  .layer-verdict {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 6px;
    display: inline-block;
  }
  .layer-verdict.neutral {
    background: rgba(255,255,255,0.04);
    color: var(--muted);
  }
  .layer-verdict.good {
    background: rgba(139, 92, 246, 0.12);
    color: var(--accent);
  }
  .layer-note {
    margin-top: 28px;
    font-size: 0.875rem;
    color: var(--muted);
    text-align: center;
    padding: 16px;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
  }
  .layer-note code {
    color: var(--accent-2);
    font-size: 0.8rem;
  }

  /* ── HOW IT WORKS ── */
  .how-section {
    padding: 100px 0;
    border-top: 1px solid var(--border-muted);
  }
  .blast-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
    margin-top: 0;
  }
  .blast-card {
    background: var(--bg-card);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius);
    padding: 36px;
  }
  .blast-after {
    border-color: rgba(139, 92, 246, 0.25);
    background: linear-gradient(145deg, rgba(139, 92, 246, 0.05), var(--bg-card));
  }
  .blast-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .blast-time {
    font-family: var(--mono);
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--muted);
    line-height: 1;
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }
  .blast-time-good {
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .blast-sub {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 20px;
  }
  .blast-bar-wrap {
    height: 6px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .blast-bar { height: 100%; border-radius: 3px; }
  .blast-bar-full  { width: 100%; background: var(--muted-2); }
  .blast-bar-small { width: 4%;   background: linear-gradient(90deg, var(--accent), var(--accent-2)); }
  .blast-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .blast-vs {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--muted-2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── TIERS ── */
  .tiers-section {
    padding: 100px 0;
    border-top: 1px solid var(--border-muted);
  }
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 56px;
  }
  .tier-card {
    background: var(--bg-card);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius);
    padding: 28px;
  }
  .tier-card-mid {
    border-color: rgba(139, 92, 246, 0.25);
    background: linear-gradient(145deg, rgba(139, 92, 246, 0.06), var(--bg-card));
  }
  .tier-num {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--muted);
    background: rgba(255,255,255,0.06);
    padding: 4px 10px;
    border-radius: 6px;
    display: inline-block;
    margin-bottom: 8px;
  }
  .tier-num.t2 { color: var(--accent); background: rgba(139,92,246,0.12); }
  .tier-num.t3 { color: var(--accent-2); background: rgba(6,182,212,0.1); }
  .tier-score {
    font-size: 0.72rem;
    color: var(--muted-2);
    margin-bottom: 14px;
    font-family: var(--mono);
  }
  .tier-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 12px;
  }
  .tier-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .tier-desc code {
    color: var(--accent-2);
    font-size: 0.8rem;
  }
  .tier-stat {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 10px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.03);
    border-radius: var(--radius-sm);
  }
  .tier-stat-val {
    font-family: var(--mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-bright);
  }
  .tier-stat-label {
    font-size: 0.75rem;
    color: var(--muted);
  }
  .tier-langs {
    font-size: 0.72rem;
    color: var(--muted-2);
    font-family: var(--mono);
  }

  /* ── FEATURES ── */
  .features-section {
    padding: 100px 0;
    border-top: 1px solid var(--border-muted);
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 56px;
  }
  .feat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius);
    padding: 28px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .feat-card:hover {
    border-color: rgba(139, 92, 246, 0.3);
    transform: translateY(-2px);
  }
  .feat-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .feat-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 10px;
  }
  .feat-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.75;
  }
  .feat-desc code {
    color: var(--accent-2);
    font-size: 0.78rem;
  }

  /* ── PERFORMANCE ── */
  .perf-section {
    padding: 100px 0;
    border-top: 1px solid var(--border-muted);
  }
  .perf-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 28px;
  }
  .perf-stat {
    background: var(--bg-card);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius);
    padding: 28px 24px;
    text-align: center;
  }
  .perf-val {
    font-family: var(--mono);
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
  }
  .perf-unit {
    font-size: 1.4rem;
  }
  .perf-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }
  .perf-detail {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .perf-table-wrap {
    overflow-x: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border-muted);
    align-self: start;
  }
  .perf-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .perf-table thead th {
    background: rgba(255,255,255,0.03);
    color: var(--muted);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 12px 20px;
    text-align: left;
    border-bottom: 1px solid var(--border-muted);
  }
  .perf-table tbody tr {
    border-bottom: 1px solid var(--border-muted);
    transition: background 0.12s;
  }
  .perf-table tbody tr:last-child { border-bottom: none; }
  .perf-table tbody tr:hover { background: rgba(255,255,255,0.02); }
  .perf-table td {
    padding: 12px 20px;
    color: var(--muted);
  }
  .perf-table td code {
    color: var(--accent-2);
    font-size: 0.8rem;
  }
  .mono-val {
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--text) !important;
  }
  .good-val { color: var(--green) !important; }

  /* ── LANGUAGES ── */
  .lang-section {
    padding: 100px 0;
    border-top: 1px solid var(--border-muted);
  }
  .lang-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  .lang-card {
    background: var(--bg-card);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius);
    padding: 28px 24px;
    text-align: center;
    transition: border-color 0.2s, transform 0.2s;
  }
  .lang-card:hover {
    border-color: rgba(139, 92, 246, 0.3);
    transform: translateY(-2px);
  }
  .lang-icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 0.85rem;
    font-weight: 700;
    margin: 0 auto 14px;
  }
  .rust-icon { background: rgba(247, 76, 0, 0.12);  color: #f97316; border: 1px solid rgba(247,76,0,0.2); }
  .ts-icon   { background: rgba(59, 130, 246, 0.12); color: #60a5fa; border: 1px solid rgba(59,130,246,0.2); }
  .py-icon   { background: rgba(234, 179, 8, 0.12);  color: #facc15; border: 1px solid rgba(234,179,8,0.2); }
  .dart-icon { background: rgba(6, 182, 212, 0.12);  color: #22d3ee; border: 1px solid rgba(6,182,212,0.2); }
  .lang-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 10px;
  }
  .lang-tiers {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-bottom: 12px;
  }
  .ltag {
    font-family: var(--mono);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.06em;
  }
  .ltag.t1 { background: rgba(255,255,255,0.07); color: var(--muted); }
  .ltag.t2 { background: rgba(139,92,246,0.15);  color: var(--accent); }
  .lang-detail {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 10px;
  }
  .lang-server {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--muted-2);
  }

  /* ── AGENT SECTION ── */
  .agent-section {
    padding: 100px 0;
    border-top: 1px solid var(--border-muted);
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(139,92,246,0.06), transparent);
  }
  .agent-flow {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    gap: 8px;
    align-items: start;
    margin-top: 56px;
  }
  .flow-step {
    background: var(--bg-card);
